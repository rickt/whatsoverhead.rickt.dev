#
# whatsoverhead env
#

# adsb
ADSB_API="https://opendata.adsb.fi/api/v2"
AIRPORTS_CONFIG_PATH=config/airports.json
POLL_SECRET_NAME=whatsoverhead_poll_secret

# app
APP_NAME="whatsoverhead.rickt.dev API"
APP_VERSION=2.0.2
DEV=False
DISTANCE=5.0

# cloud run
CLOUDRUN_CONCURRENCY=85
CLOUDRUN_CPU=1
CLOUDRUN_MEMORY=1
CLOUDRUN_MAXINSTANCES=1
CLOUDRUN_MININSTANCES=1

# firestore
FIRESTORE_COLLECTION=airport_cache
FIRESTORE_DB=whatsoverhead
FIRESTORE_LOCK_DOC=locks/poller
POLL_SLEEP_MS=1100
ACTIVE_VIEW_WINDOW_SECONDS=604800

# gcp
ENDPOINT=whatsoverhead
GCP_LOG=WhatsOverhead
GCP_PROJECT_ID=rickts-new-dev-project
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT=whats-overhead@rickts-new-dev-project.iam.gserviceaccount.com
PORT=8080

# EOF
